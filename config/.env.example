# Claude authentication — OAuth token from your Claude Max subscription
# After running `claude` locally and logging in, copy the token from ~/.claude.json
CLAUDE_CODE_OAUTH_TOKEN=

# Discord bot credentials
# Create a bot at https://discord.com/developers/applications
DISCORD_BOT_TOKEN=
DISCORD_APP_ID=
DISCORD_GUILD_ID=
DISCORD_CHANNEL_ID=

# Timezone for cron jobs (e.g. America/New_York, Europe/London, UTC)
AGENT_TIMEZONE=UTC

# Optional: path overrides
# WORKSPACE_DIR=/workspace

# DO NOT SET ANTHROPIC_API_KEY — it overrides OAuth and bills your API account per token
